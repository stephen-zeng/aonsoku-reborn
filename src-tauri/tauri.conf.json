{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aonsoku",
  "version": "0.30.0",
  "identifier": "com.realtvop.aonsoku",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Aonsoku",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 15, "y": 20 },
        "visible": true
      }
    ],
    "security": {
      "capabilities": ["main"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../resources/icons/icon.png",
      "../resources/icons/icon.icns",
      "../resources/icons/icon.ico"
    ]
  }
}
