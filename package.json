{
  "name": "aonsoku",
  "private": true,
  "version": "0.30.0",
  "description": "A modern desktop client for Navidrome/Subsonic servers.",
  "author": {
    "name": "realtvop"
  },
  "license": "MIT",
  "main": "./out/main/index.js",
  "type": "module",
  "productName": "Aonsoku",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "lint:check": "biome check --write",
    "lint:format": "biome format --write",
    "cy:open": "cypress open",
    "test": "cypress run --component",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "electron:start": "electron-forge start",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build",
    "make": "pnpm electron:build && electron-forge make",
    "publish": "pnpm electron:build && electron-forge publish",
    "build:unpack": "pnpm electron:build",
    "build:win": "pnpm electron:build && electron-forge make --platform win32",
    "build:mac": "pnpm electron:build && electron-forge make --platform darwin",
    "build:linux": "pnpm electron:build && electron-forge make --platform linux",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/realtvop/aonsoku-reborn.git"
  },
